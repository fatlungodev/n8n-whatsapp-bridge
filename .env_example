PORT=3001
WEB_PASSWORD=replace-with-a-strong-console-password
SESSION_SECRET=replace-with-a-long-random-session-secret
DISABLE_LOGIN=false
N8N_API_KEY=replace-with-a-long-random-api-key
ALLOW_UNAUTHENTICATED_API=false

# Optional: only allow specific WhatsApp numbers to trigger the incoming webhook.
# Example: 85291234567,85298765432
WHATSAPP_ALLOW_LIST=

# n8n webhook that receives inbound WhatsApp messages from this bridge.
WHATSAPP_INCOMING_WEBHOOK_URL=

# Optional secret forwarded to the inbound webhook request.
WHATSAPP_INCOMING_WEBHOOK_SECRET_HEADER=x-webhook-secret
WHATSAPP_INCOMING_WEBHOOK_SECRET=

# Optional retry tuning for the persistent inbound webhook queue.
INCOMING_WEBHOOK_RETRY_BASE_MS=2000
INCOMING_WEBHOOK_RETRY_MAX_MS=300000
INCOMING_WEBHOOK_MAX_ATTEMPTS=25

# Rotate audit and console logs after they reach this size in MB.
LOG_MAX_SIZE_MB=10
